# autoresearch-gen — environment config
# Copy to .env and fill in your values.

# ── Default model ──────────────────────────────────────────
# Used when --model is not passed. Any model ID works here.
# Examples: claude-sonnet-4-20250514, gpt-4o, deepseek-r1, ollama/llama3
DEFAULT_MODEL=claude-sonnet-4-20250514

# ── API keys ───────────────────────────────────────────────
# Only the key for your chosen provider is required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# ── LiteLLM (optional) ────────────────────────────────────
# Set LITELLM_API_BASE to route all LLM calls through a LiteLLM proxy.
# When set, any model ID is sent to this endpoint using OpenAI-compatible format.
# See: https://docs.litellm.ai/docs/proxy/quick_start
#
# LITELLM_API_BASE=http://localhost:4000
# LITELLM_API_KEY=sk-litellm-...
